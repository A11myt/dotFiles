{
  "$schema": "$XDG_CONFIG_HOME/swaync/configSchema.json",
  "control-center-layer": "overlay",
  "control-center-margin-bottom": 0,
  "control-center-margin-left": 0,
  "control-center-margin-right": 10,
  "control-center-margin-top": 0,
  "control-center-width": 500,
  "cssPriority": "user",
  "control-center-positionX": "right",
  "control-center-positionY": "center",
  "fit-to-screen": true,
  "hide-on-action": false,
  "hide-on-clear": false,
  "image-visibility": "when-available",
  "keyboard-shortcuts": true,
  "layer": "top",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-icon-size": 40,
  "notification-inline-replies": true,
  "notification-visibility": {},
  "notification-window-width": 400,
  "positionX": "right",
  "positionY": "top",
  "script-fail-notify": true,
  "scripts": {},
  "timeout": 10,
  "timeout-critical": 0,
  "timeout-low": 5,
  "transition-time": 100,
  "widget-config": {
    "buttons-grid": {
      "actions": [
        {
          "active": false,
          "command": "nmcli radio wifi toggle",
          "label": "󰤄",
          "type": "toggle",
          "update_command": "[ \"$(nmcli radio wifi)\" = 'enabled' ] && echo 'true' || echo 'false'"
        },
        {
          "active": false,
          "command": "swaync-client -d",
          "label": "",
          "type": "toggle"
        },
        {
          "active": false,
          "command": "obs",
          "label": "󰄀",
          "type": "button"
        },
        {
          "active": false,
          "command": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
          "label": "󰕧",
          "type": "toggle",
          "update_command": "wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q MUTED && echo 'true' || echo 'false'"
        },
        {
          "active": false,
          "command": "swaync-client -t",
          "label": "",
          "type": "toggle"
        }
      ]
    },
    "mpris": {
      "image-radius": 12,
      "image-size": 96
    },
    "title": {
      "text": "Notifications",
      "button-text": "󰎟 Clear",
      "clear-all-button": true
    },
    "volume": {
      "label": "",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": true
    }
  },
  "widgets": ["title", "notifications", "buttons-grid", "mpris", "volume"]
}
